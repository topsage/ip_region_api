[Unit]
Description=IP Region API (Shell Edition)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/ip_region_api_project
Environment=IP2REGION_XDB_PATH=/opt/ip_region_api_project/ip2region.xdb
Environment=IP2REGION_DB_VERSION=ipv4
ExecStart=/usr/bin/bash /opt/ip_region_api_project/linux_shell/bin/serve.sh --host 0.0.0.0 --port 8011 --xdb-path /opt/ip_region_api_project/ip2region.xdb
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
